{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "frappe-ui": [
                "../node_modules/frappe-ui"
            ]
        },
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "allowJs": true,
        "checkJs": true,
        "jsx": "preserve"
    },
    "include": [
        "src/**/*",
        "src/global.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}